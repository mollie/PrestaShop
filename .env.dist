#DEV=development
#TEST=test shop
#PRE_PROD=preprod shop
#GITHUB=module from github
#MARKETPLACE=module from marketplace
MODULE_ENV='GITHUB'

# Segment Analytics API Key (optional)
# If not set, uses the default key from Config::SEGMENT_KEY
# To use a custom key, uncomment and set your Segment Write Key:
SEGMENT_API_KEY='your_segment_write_key_here'
